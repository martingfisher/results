<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduce) {
    gsap.registerPlugin(ScrollTrigger);

    const heroCtaButtons = gsap.utils.toArray<HTMLElement>('[data-gsap="hero-cta"] .btn');
    gsap.set(heroCtaButtons, { autoAlpha: 0, y: 18, scale: 0.98 });

    gsap.from('[data-gsap="word"]', {
      yPercent: 110,
      opacity: 0,
      duration: 0.9,
      stagger: 0.06,
      ease: 'power4.out',
    });

    gsap.from('[data-gsap="float-card"]', {
      y: 42,
      rotate: 0,
      opacity: 0,
      duration: 0.9,
      stagger: 0.08,
      delay: 0.25,
      ease: 'power3.out',
    });

    gsap.from('[data-gsap="hero-panel"]', {
      y: 24,
      opacity: 0,
      duration: 0.72,
      delay: 0.28,
      ease: 'power3.out',
    });

    if (heroCtaButtons.length) {
      gsap.to(heroCtaButtons, {
        autoAlpha: 1,
        y: 0,
        scale: 1,
        duration: 0.48,
        stagger: 0.1,
        delay: 11.6,
        ease: 'back.out(1.35)',
      });
    }

    const chatRoot = document.querySelector('[data-chat-loop] .concept-chat');
    const turns = gsap.utils.toArray<HTMLElement>('[data-chat-loop] .chat-turn');

    if (chatRoot && turns.length) {
      chatRoot.classList.add('js-chat-loop');

      const timeline = gsap.timeline({
        repeat: -1,
        repeatDelay: 0,
        delay: 0.9,
        defaults: { ease: 'power2.out' },
      });

      gsap.set(turns, { autoAlpha: 1 });
      gsap.set('[data-chat-loop] .typing-note, [data-chat-loop] .concept-msg', { autoAlpha: 0 });

      turns.forEach((turn) => {
        const typing = turn.querySelector('.typing-note');
        const message = turn.querySelector('.concept-msg');
        const fromX = turn.classList.contains('agency') ? 36 : -36;

        timeline
          .fromTo(typing, { autoAlpha: 0, x: fromX * 0.45 }, { autoAlpha: 1, x: 0, duration: 0.18 })
          .to(typing, { autoAlpha: 0, duration: 0.12 }, '+=0.52')
          .fromTo(
            message,
            { autoAlpha: 0, x: fromX, y: 8, scale: 0.98 },
            { autoAlpha: 1, x: 0, y: 0, scale: 1, duration: 0.34, ease: 'back.out(1.35)' },
            '<'
          )
          .to({}, { duration: 0.72 });
      });

      timeline
        .to({}, { duration: 3.55 })
        .to('[data-chat-loop] .chat-turn', { autoAlpha: 0, y: -10, duration: 0.35, stagger: 0.025, ease: 'power2.in' })
        .set('[data-chat-loop] .chat-turn', { clearProps: 'transform', autoAlpha: 1 })
        .set('[data-chat-loop] .typing-note, [data-chat-loop] .concept-msg', { autoAlpha: 0, clearProps: 'transform' });
    }

    gsap.utils.toArray<HTMLElement>('[data-gsap="portfolio-panel"]').forEach((panel, index) => {
      const image = panel.querySelector('img');
      const copyItems = panel.querySelectorAll('.portfolio-copy > *');
      const direction = index % 2 === 0 ? -1 : 1;

      panel.classList.add('is-animated');

      gsap.fromTo(
        panel,
        { autoAlpha: 0, y: 72, x: direction * 34 },
        {
          autoAlpha: 1,
          y: 0,
          x: 0,
          duration: 0.9,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: panel,
            start: 'top 82%',
            once: true,
          },
        }
      );

      gsap.fromTo(
        copyItems,
        { autoAlpha: 0, y: 32 },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.7,
          stagger: 0.08,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: panel,
            start: 'top 72%',
            once: true,
          },
        }
      );

      if (image) {
        gsap.to(image, {
          yPercent: -7,
          scale: 1.04,
          ease: 'none',
          scrollTrigger: {
            trigger: panel,
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        });
      }
    });
  }
</script>

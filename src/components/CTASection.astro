---
interface Props {
  title?: string;
  text?: string | string[];
  primaryLabel?: string;
  secondaryLabel?: string;
}

const {
  title = "Let’s start something useful.",
  text = "Looking to develop your brand, generate high-converting leads, or get a clearer view of what your marketing is doing? We should talk.",
  primaryLabel = "Book a call",
  secondaryLabel = "Send an enquiry",
} = Astro.props;

const paragraphs = Array.isArray(text) ? text : [text];
---

<section class="cta-band">
  <p class="eyebrow">Next step</p>
  <h2>{title}</h2>
  {paragraphs.map((p) => <p>{p}</p>)}
  <div class="actions">
    <a class="btn primary" href="/contact/">{primaryLabel}</a>
    <a class="btn secondary" href="mailto:hello@resultsyoucanmeasure.com">{secondaryLabel}</a>
  </div>
</section>

---
interface Props {
  title?: string;
  text?: string | string[];
  primaryLabel?: string;
  secondaryLabel?: string;
}
const { title, text, primaryLabel, secondaryLabel } = Astro.props;
const paragraphs = Array.isArray(text) ? text : [text ?? "Looking to develop your brand, generate leads, or get a clearer view of what your marketing is doing? We should talk."];
---

<section class="cta-band">
  <p class="eyebrow">Next step</p>
  <h2>{title ?? "Start something useful."}</h2>
  {paragraphs.map((p) => <p>{p}</p>)}
  <div class="actions">
    <a class="btn primary" href="/contact/">{primaryLabel ?? "Book a call"}</a>
    <a class="btn secondary" href="mailto:hello@resultsyoucanmeasure.com">{secondaryLabel ?? "Send an enquiry"}</a>
  </div>
</section>

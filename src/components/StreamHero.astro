---
interface Message {
  from: 'client' | 'agency';
  text: string;
}

interface Props {
  streamId: string;
  poster: string;
  eyebrow: string;
  title: string;
  summary: string;
  cta: string;
  secondaryCta?: string;
  messages: Message[];
}

const { streamId, poster, eyebrow, title, summary, cta, secondaryCta, messages } = Astro.props;

const CUSTOMER_CODE = import.meta.env.CF_STREAM_CUSTOMER_CODE ?? '';
const iframeSrc = CUSTOMER_CODE
  ? `https://customer-${CUSTOMER_CODE}.cloudflarestream.com/${streamId}/iframe?autoplay=true&muted=true&loop=true&controls=false&preload=auto`
  : null;
---

<section class="stream-hero">
  <!-- Full-width background video -->
  <div class="stream-bg" aria-hidden="true">
    {iframeSrc ? (
      <iframe
        src={iframeSrc}
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        title=""
      ></iframe>
    ) : (
      <>
        <!-- Fallback: Stream web component until customer code is set -->
        <stream
          src={streamId}
          autoplay
          muted
          loop
          controls="false"
          preload="auto"
          playsinline
          poster={poster}
          style="position:absolute;inset:0;width:100%;height:100%;"
        ></stream>
        <script is:inline src="https://embed.cloudflarestream.com/embed/sdk.latest.js"></script>
        <script is:inline>
          (function() {
            function initStream() {
              var el = document.querySelector('.stream-bg stream');
              if (!el || typeof Stream === 'undefined') return;
              var player = Stream(el);
              player.muted = true;
              player.loop = true;
              player.play().catch(function() {});
            }
            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', initStream);
            } else {
              initStream();
            }
          })();
        </script>
      </>
    )}
  </div>

  <!-- Dark overlay -->
  <div class="stream-overlay" aria-hidden="true"></div>

  <!-- Copy -->
  <div class="stream-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p>{summary}</p>
    <div class="stream-ctas">
      <a class="btn primary" href="/contact/">{cta}</a>
      {secondaryCta && <a class="btn secondary" href="/contact/">{secondaryCta}</a>}
    </div>
  </div>

  <!-- Chat rail -->
  <aside class="message-rail" aria-label="Example client conversation">
    <ol class="chat-stack">
      {messages.map((message, index) => (
        <li class:list={['chat-bubble', message.from]} style={`--i:${index}`}>
          <span class="chat-name">{message.from === 'agency' ? 'RYCM team' : 'Client'}</span>
          <span set:html={message.text} />
        </li>
      ))}
      <!-- Typing indicator — shown by GSAP before each agency reply -->
      <li class="chat-bubble agency typing-indicator" aria-hidden="true">
        <span class="chat-name">RYCM team</span>
        <span class="typing-dots"><span></span><span></span><span></span></span>
      </li>
    </ol>
  </aside>
</section>

<script>
  import gsap from 'gsap';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const allBubbles = Array.from(document.querySelectorAll<HTMLElement>('.stream-hero .chat-bubble'));
  const typingEl = document.querySelector<HTMLElement>('.stream-hero .typing-indicator')!;
  const bubbles = allBubbles.filter((b) => !b.classList.contains('typing-indicator'));

  if (!reduce && bubbles.length) {
    // Collapse all bubbles in-flow (no display:none to avoid layout snaps)
    const collapse = (el: HTMLElement) => {
      el.style.animation = 'none';
      gsap.set(el, { height: 0, paddingTop: 0, paddingBottom: 0, marginBottom: 0, opacity: 0, overflow: 'hidden' });
    };
    [...bubbles, typingEl].forEach(collapse);

    const expand = (el: HTMLElement, tl: gsap.core.Timeline, t: number, isAgency: boolean) => {
      // First expand the height so the stack grows naturally
      tl.to(el, { height: 'auto', paddingTop: 11, paddingBottom: 11, marginBottom: 11, duration: 0.22, ease: 'power2.out' }, t);
      // Then slide the content in from the side
      tl.fromTo(el,
        { opacity: 0, x: isAgency ? 30 : -30 },
        { opacity: 1, x: 0, duration: 0.48, ease: 'back.out(1.3)' },
        t + 0.12
      );
    };

    function playLoop() {
      const tl = gsap.timeline();
      let t = 0.4;

      bubbles.forEach((bubble) => {
        const isAgency = bubble.classList.contains('agency');

        if (isAgency) {
          // Expand typing indicator
          tl.to(typingEl, { height: 'auto', paddingTop: 11, paddingBottom: 11, marginBottom: 11, duration: 0.22, ease: 'power2.out' }, t);
          tl.fromTo(typingEl,
            { opacity: 0, x: 30 },
            { opacity: 1, x: 0, duration: 0.4, ease: 'power2.out' },
            t + 0.12
          );
          t += 1.1; // hold typing indicator
          // Collapse typing indicator as the real bubble expands
          tl.to(typingEl, { opacity: 0, duration: 0.2 }, t);
          tl.to(typingEl, { height: 0, paddingTop: 0, paddingBottom: 0, marginBottom: 0, duration: 0.2, ease: 'power2.in' }, t + 0.1);
          t += 0.25;
        }

        expand(bubble, tl, t, isAgency);
        t += isAgency ? 0.9 : 0.8;
      });

      // Hold full conversation
      tl.to({}, { duration: 1.8 }, t);

      // Fade all out and collapse
      tl.to([...bubbles], {
        opacity: 0,
        y: -8,
        duration: 0.35,
        stagger: 0.05,
        ease: 'power2.in',
      }, t + 1.8);

      // Reset for next loop
      tl.call(() => {
        [...bubbles, typingEl].forEach(collapse);
        setTimeout(playLoop, 500);
      });
    }

    playLoop();
  }
</script>

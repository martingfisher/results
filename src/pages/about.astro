---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import TechMarquee from '../components/TechMarquee.astro';
import ConceptChat from '../components/ConceptChat.astro';
import ConceptMotion from '../components/ConceptMotion.astro';
import '../styles/concepts.css';

const aboutChat: Array<{ from: 'client' | 'agency'; text: string }> = [
  { from: 'client', text: 'We do bits of marketing all over the place. Is any of it actually working?' },
  { from: 'agency', text: 'We audited everything, kept what worked, stopped the waste, then built a simple plan.' },
  { from: 'client', text: 'What did that actually change?' },
  { from: 'agency', text: 'Clear priorities, one joined up message, campaigns that match your capacity.' },
  { from: 'client', text: 'And the numbers?' },
  { from: 'agency', text: 'Same budget, 31 percent more qualified enquiries in 90 days.' },
  { from: 'client', text: 'Now that <u>IS</u> Results You Can Measure!' },
];
---

<BaseLayout
  title="About | Bradford Marketing Agency Founded by Martin Fisher"
  description="Results You Can Measure is a founder-led marketing agency based in Bradford. Senior creative, strategic and digital marketing expertise without the agency layers."
>
  {/* ========================= SECTION 1 — HERO ========================= */}
  {/* To reorder the page, move whole SECTION blocks (from this comment   */}
  {/* down to the matching END comment) up or down as single units.       */}
  <section class="page-hero about-hero">
    <div class="about-hero-bg" aria-hidden="true"></div>
    <div class="about-hero-content">
      <p class="eyebrow">About</p>
      <h1>Big agency thinking.<br />Senior-level delivery.<br />No layers. No passengers.</h1>
      <p>Founder-led, but not built around one pair of hands. We help businesses grow through clearer positioning, smarter strategy, strong creative and measurable marketing performance.</p>
    </div>
    <aside class="message-rail" data-chat-loop>
      <ConceptChat messages={aboutChat} />
    </aside>
  </section>
  {/* ===================== END SECTION 1 — HERO ===================== */}

  {/* ============= SECTION 2 — HOW WE GOT HERE (bio) ============= */}
  <section class="section split">
    <div>
      <p class="eyebrow">How we got here</p>
      <h2>Marketing, technology, psychology and hands-on design.</h2>
    </div>
    <div class="rich-copy">
      <p>Martin started on the media side of agency life and kept moving until he had done most of the jobs himself. Creative. Direct marketing. Building the websites. Running the ecommerce. Reading the analytics afterwards to see what actually happened. That range is the whole point: he has seen how the parts connect, and how often they get sold separately.</p>
      <p>He has grown agencies, set strategy and run teams and projects for UK and international brands. RYCM is the deliberate opposite of that scale. Independent, senior, and backed by a small network of specialists he genuinely rates. One principle has survived every tool change since the start. Do not talk at people. Start a conversation.</p>
    </div>
  </section>
  {/* ========= END SECTION 2 — HOW WE GOT HERE (bio) ========= */}

  {/* === SECTION 3 — FOUNDER-LED (intro + what we do/don't + logos) === */}
  <section class="section stack-feature">
    <div class="stack-feature-row">
      <img src="/assets/projects/packaged-martin.png" alt="Martin Marketing Bloke concept packaging" loading="lazy" />
      <div>
        <p class="eyebrow">Founder-led, not precious</p>
        <h2>Comfortable where modern marketing actually happens.</h2>
        <p>From websites and ecommerce to paid media, analytics, hosting and AI-assisted content workflows, we work in the tools your marketing already depends on. No outsourcing the bits that matter, no learning on your budget.</p>
      </div>
    </div>
    <div class="do-dont">
      <article class="do-dont-yes">
        <p class="eyebrow">Here is what we do</p>
        <ul>
          <li>Craft highly original creative solutions with real commercial credibility.</li>
          <li>Understand your business needs and find the most appropriate solution.</li>
          <li>Challenge your thinking honestly, directly and constructively.</li>
          <li>Fit around your schedule and stay easy to reach.</li>
        </ul>
      </article>
      <article class="do-dont-no">
        <p class="eyebrow">And what we do not</p>
        <ul>
          <li>Give you the hard sell on products or services you do not need.</li>
          <li>Take on projects where we do not believe we can add value.</li>
          <li>Blind you with science, quoting stats instead of offering insights.</li>
        </ul>
      </article>
    </div>
    <TechMarquee copy={false} />
  </section>
  {/* === END SECTION 3 — FOUNDER-LED === */}

  {/* ========= SECTION 4 — HOW WE WORK (5-step process) ========= */}
  <section class="section process-section">
    <div class="section-head">
      <p class="eyebrow">How we work</p>
      <h2>What working together actually looks like.</h2>
      <p>No long onboarding, no account layer, no mystery. Five clear stages, and you talk to the person doing the work at every one of them.</p>
    </div>
    <ol class="process-list">
      <li class="process-step">
        <span class="process-num">01</span>
        <div>
          <h3>Listen, then audit</h3>
          <p>We start with the business, not the brief. What is working, what is quietly wasting money, and where the real opportunity actually sits.</p>
        </div>
      </li>
      <li class="process-step">
        <span class="process-num">02</span>
        <div>
          <h3>Agree the priorities</h3>
          <p>We decide what matters most and in what order, so effort goes where it moves the numbers, not where it is easiest to be busy.</p>
        </div>
      </li>
      <li class="process-step">
        <span class="process-num">03</span>
        <div>
          <h3>Build one joined-up plan</h3>
          <p>Positioning, message, channels and budget in a single plan, sized to your real capacity rather than an ideal that never ships.</p>
        </div>
      </li>
      <li class="process-step">
        <span class="process-num">04</span>
        <div>
          <h3>Do the work, senior hands on</h3>
          <p>The people who scoped it are the people who deliver it. You stay close to the work and easy to reach goes both ways.</p>
        </div>
      </li>
      <li class="process-step">
        <span class="process-num">05</span>
        <div>
          <h3>Measure and adjust</h3>
          <p>We track leads, sales and better clients, report it plainly, and change what the evidence tells us to change.</p>
        </div>
      </li>
    </ol>
  </section>
  {/* === END SECTION 4 — HOW WE WORK === */}

  {/* ========= SECTION 5 — PROOF (case-study cards) ========= */}
  <section class="section about-proof">
    <div class="section-head">
      <p class="eyebrow">Proof</p>
      <h2>The thinking, applied to real work.</h2>
      <p>None of this means much without evidence. Here is the same approach on real briefs, with the measured outcomes attached rather than implied.</p>
    </div>
    <div class="proof-cards">
      <a class="proof-card" href="/case-studies/handco-hairdressing/">
        <span class="proof-stat">92 / 93 / 100 / 100</span>
        <strong>H&amp;Co Hairdressing</strong>
        <span>Big-brand PageSpeed on a two-stylist salon budget.</span>
      </a>
      <a class="proof-card" href="/case-studies/lolly/">
        <span class="proof-stat">225,000+</span>
        <strong>Lolly</strong>
        <span>A Webflow site for a hospitality platform operating at real scale.</span>
      </a>
      <a class="proof-card" href="/case-studies/f8-group/">
        <span class="proof-stat">5 audiences</span>
        <strong>F8 Group</strong>
        <span>A complex engineering offer made clear, with a route in for each buyer.</span>
      </a>
    </div>
    <p class="proof-more"><a class="btn secondary" href="/case-studies/">See all the work</a></p>
  </section>
  {/* === END SECTION 5 — PROOF === */}

  {/* === SECTION 6 — CTA ("Start something useful") === */}
  <CTASection />
  {/* === END SECTION 6 — CTA === */}

  <ConceptMotion />
</BaseLayout>

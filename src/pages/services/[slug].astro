---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceChat from '../../components/ServiceChat.astro';
import StreamHero from '../../components/StreamHero.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CTASection from '../../components/CTASection.astro';
import ServiceMotion from '../../components/ServiceMotion.astro';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({ params: { slug: service.data.pageSlug }, props: { service } }));
}

const { service } = Astro.props;
const { Content } = await render(service);
const caseStudies = await getCollection('caseStudies');
const related = caseStudies.filter((study) => service.data.relatedCaseStudies.includes(study.data.pageSlug));
---

<BaseLayout title={service.data.title} description={service.data.summary}>
  {service.data.streamId ? (
    <StreamHero
      streamId={service.data.streamId}
      poster={service.data.poster}
      eyebrow={service.data.eyebrow}
      title={service.data.title}
      summary={service.data.summary}
      cta={service.data.cta}
      messages={service.data.chat}
    />
  ) : (
    <section class="page-hero service-hero">
      <div>
        <p class="eyebrow">{service.data.eyebrow}</p>
        <h1>{service.data.title}</h1>
        <p>{service.data.summary}</p>
        <a class="btn primary" href="/contact/">{service.data.cta}</a>
      </div>
      <ServiceChat video={service.data.video} poster={service.data.poster} messages={service.data.chat} label={`${service.data.title} example conversation`} />
    </section>
  )}

  {service.data.introSection ? (
    <section class="section intro-section">
      <div class="intro-inner">
        <h2>{service.data.introSection.heading}</h2>
        <div class="intro-body">
          {service.data.introSection.body.split('\n\n').map((para) => <p>{para}</p>)}
        </div>
        <div class="intro-ctas">
          <a class="btn primary" href="/contact/">{service.data.introSection.primary}</a>
          {service.data.introSection.secondary && <a class="btn secondary" href="/contact/">{service.data.introSection.secondary}</a>}
        </div>
      </div>
    </section>
  ) : (
    <section class="section split">
      <div>
        <p class="eyebrow">{service.data.bodyEyebrow ?? 'How we help'}</p>
        <h2>{service.data.bodyHeading ?? 'Enough strategy to be useful. Enough action to move.'}</h2>
      </div>
      <div class="rich-copy"><Content /></div>
    </section>
  )}

  {service.data.serviceAreas && (
    <section class="section service-areas">
      <div class="section-head">
        <p class="eyebrow">What we help with</p>
        <h2>Practical strategic support across the areas that influence growth.</h2>
      </div>
      <div class="service-area-grid">
        {service.data.serviceAreas.map((area) => (
          <div class="service-area-card">
            <h3>{area.title}</h3>
            <p>{area.description}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  {service.data.approach ? (
    <section class="section approach-section">
      <div class="approach-intro">
        <p class="eyebrow">Our approach</p>
        <h2>{service.data.approach.heading}</h2>
        <div class="approach-body">
          {service.data.approach.intro.split('\n\n').map((para) => <p>{para}</p>)}
        </div>
      </div>
      <div class="metric-grid">
        {service.data.benefits.map((benefit) => <div class="metric-card">{benefit}</div>)}
      </div>
    </section>
  ) : (
    <section class="section">
      <div class="metric-grid">
        {service.data.benefits.map((benefit) => <div class="metric-card">{benefit}</div>)}
      </div>
    </section>
  )}

  {service.data.editorialSections && service.data.editorialSections.map((ed) => (
    <section class="section editorial-section">
      <div class="editorial-inner">
        <h2>{ed.heading}</h2>
        <div class="editorial-body">
          {ed.body.split('\n\n').map((para) => <p>{para}</p>)}
        </div>
      </div>
    </section>
  ))}

  {service.data.process && (
    <section class="section process-section">
      <div class="section-head">
        <p class="eyebrow">How we work</p>
        <h2>A practical process built around clarity.</h2>
      </div>
      <ol class="process-list">
        {service.data.process.map((step) => (
          <li class="process-step">
            <span class="process-num">{step.step}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>
  )}

  <section class="section faq-list">
    <p class="eyebrow">Questions</p>
    <h2>What clients usually want to know.</h2>
    {service.data.faqs.map((faq) => (
      <details>
        <summary>{faq.question}</summary>
        <p>{faq.answer}</p>
      </details>
    ))}
  </section>

  {related.length > 0 && (
    <section class="section">
      <div class="section-head">
        <p class="eyebrow">Related proof</p>
        <h2>Work with similar thinking behind it.</h2>
      </div>
      <div class="case-feature-grid">
        {related.map((study) => (
          <CaseStudyCard title={study.data.title} href={`/case-studies/${study.data.pageSlug}/`} summary={study.data.summary} image={study.data.heroImage} sector={study.data.sector} />
        ))}
      </div>
    </section>
  )}

  {service.data.closingCta ? (
    <section class="section closing-cta-section">
      <div class="closing-cta">
        <h2>{service.data.closingCta.heading}</h2>
        {service.data.closingCta.subheading && <p class="closing-sub">{service.data.closingCta.subheading}</p>}
        {service.data.closingCta.body && <p>{service.data.closingCta.body}</p>}
        <div class="closing-cta-btns">
          <a class="btn primary" href="/contact/">{service.data.closingCta.primary}</a>
          {service.data.closingCta.secondary && <a class="btn outline" href="/contact/">{service.data.closingCta.secondary}</a>}
        </div>
      </div>
    </section>
  ) : (
    <CTASection title={`Want clearer ${service.data.title.toLowerCase()}?`} text="Book a call and we will talk through what is working, what is wasting attention, and what to measure first." />
  )}
  <ServiceMotion />
</BaseLayout>

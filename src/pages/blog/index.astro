---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout
  title="Marketing Blog | Practical Thinking for Business Owners"
  description="Articles from Results You Can Measure on SEO, PPC, branding, social media and marketing strategy. Practical thinking for business owners who want clearer decisions and better results."
>
  <section class="page-hero compact">
    <p class="eyebrow">Blog</p>
    <h1>Notes on making marketing easier to understand and measure.</h1>
    <p>Practical articles for business owners who want clearer decisions, better leads and more accountability from their marketing.</p>
  </section>

  <section class="section">
    <div class="blog-grid">
      {posts.map((post) => (
        <article class="blog-card">
          <p class="eyebrow">{post.data.category}</p>
          <h2><a href={`/blog/${post.data.pageSlug}/`}>{post.data.title}</a></h2>
          <p class="blog-date">{new Date(post.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
          <p>{post.data.summary}</p>
          <a class="text-link" href={`/blog/${post.data.pageSlug}/`}>Read article</a>
        </article>
      ))}
    </div>
  </section>

  <CTASection
    title="Your market may not be the problem"
    text={[
      'Sometimes the issue is the way everyone is looking at it.',
      'We help businesses find opportunities others miss. New audiences. Untapped positioning. Better ways to communicate value. Often the fastest growth comes from changing the angle, not increasing the budget.',
      "If your marketing feels stuck, predictable, or difficult to measure, let's look at it differently.",
    ]}
    primaryLabel="Book a strategy call"
    secondaryLabel="Send an enquiry"
  />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Book a Call | Contact Results You Can Measure"
  description="Talk to Results You Can Measure about your marketing. Based in Bradford, we help UK businesses get clearer strategy, better leads and more accountable marketing."
>
  <section class="page-hero contact-hero">
    <div>
      <p class="eyebrow">Book a call</p>
      <h1>Sometimes the biggest opportunity is seeing the problem differently.</h1>
      <p>We help businesses find clearer positioning, stronger communication and more measurable ways to grow. On a call we will talk through where you are, what is already in motion, and what would make the biggest practical difference.</p>
    </div>
    <div class="contact-panel contact-panel--form">
      <script is:inline src="https://elfsightcdn.com/platform.js" async></script>
      <div class="elfsight-app-25af00f9-81ef-430e-82db-f67c0a4ff8b6" data-elfsight-app-lazy></div>
    </div>
  </section>
</BaseLayout>

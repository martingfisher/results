---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Book a Call | Contact Results You Can Measure"
  description="Talk to Results You Can Measure about your marketing. Based in Bradford, we help UK businesses get clearer strategy, better leads and more accountable marketing."
>
  <section class="page-hero contact-hero">
    <div>
      <p class="eyebrow">Book a call</p>
      <h1>Tell us what you need to make clearer, faster or more measurable.</h1>
      <p>We will talk through where you are, what is already in motion, and what would make the biggest practical difference.</p>
      <div class="actions">
        <a class="btn primary" href="mailto:hello@resultsyoucanmeasure.com?subject=Book%20a%20call%20with%20RYCM">Book a call by email</a>
        <a class="btn secondary" href="tel:+447973321771">Call 07973 321 771</a>
      </div>
    </div>
    <div class="contact-panel">
      <p class="eyebrow">What happens next</p>
      <ol>
        <li><strong>Short conversation.</strong> We understand your business, stage and pressure points.</li>
        <li><strong>Honest recommendation.</strong> We say what looks useful and what can wait.</li>
        <li><strong>Clear next step.</strong> You get a practical route, not a vague proposal fog.</li>
      </ol>
      <p><a href="mailto:hello@resultsyoucanmeasure.com">hello@resultsyoucanmeasure.com</a></p>
    </div>
  </section>

  <section class="section contact-form-section">
    <div class="contact-form-wrap">
      <script is:inline src="https://elfsightcdn.com/platform.js" async></script>
      <div class="elfsight-app-25af00f9-81ef-430e-82db-f67c0a4ff8b6" data-elfsight-app-lazy></div>
    </div>
  </section>
</BaseLayout>

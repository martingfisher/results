---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CTASection from '../../components/CTASection.astro';
import MomentumCards from '../../components/MomentumCards.astro';

const caseStudyOrder = [
  'alpha-moisture-systems',
  'brightbird',
  'experience-community',
  'goodees',
  'insurance-for-group',
  'insurance-for-ngos',
  'pallet-plus',
  'presentation-spaces',
  'lolly',
];

const caseStudies = (await getCollection('caseStudies')).sort((a, b) => {
  const aIndex = caseStudyOrder.indexOf(a.data.pageSlug);
  const bIndex = caseStudyOrder.indexOf(b.data.pageSlug);

  return (aIndex === -1 ? 999 : aIndex) - (bIndex === -1 ? 999 : bIndex);
});

const STREAM_ID = '1be64aadf989e269c5ce877f20d8848f';
const CUSTOMER_CODE = import.meta.env.CF_STREAM_CUSTOMER_CODE ?? 'eo7jhn0ipdxweq9b';
const streamSrc = `https://customer-${CUSTOMER_CODE}.cloudflarestream.com/${STREAM_ID}/iframe?autoplay=true&muted=true&loop=true&controls=false&preload=auto`;
---

<BaseLayout
  title="Case Studies | Marketing, Branding and Web Work That Paid Off"
  description="Real client projects from Results You Can Measure. Branding, web development, SEO and campaign work for UK businesses — with the outcomes to show for it."
>
  <section class="page-hero compact case-index-hero">
    <div class="stream-bg" aria-hidden="true">
      <iframe
        src={streamSrc}
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        title=""
        loading="lazy"
      ></iframe>
    </div>
    <div class="stream-overlay" aria-hidden="true"></div>
    <p class="eyebrow">Selected projects</p>
    <h1>Work that made the offer easier to choose.</h1>
    <p class="case-index-kicker">Every project here started with a real business challenge — unclear positioning, weak web presence, campaigns that were not converting.</p>
    <p class="case-index-lede">
      What you see below is the result of joining the thinking up: branding that earns trust, websites that convert, marketing that tracks back to leads and sales.
    </p>
  </section>
  <section class="section case-index-section">
    <div class="case-feature-grid">
      {caseStudies.map((study) => (
        <CaseStudyCard
          title={study.data.title}
          href={`/case-studies/${study.data.pageSlug}/`}
          summary={study.data.summary}
          image={study.data.heroImage}
          sector={study.data.sector}
          client={study.data.client}
          services={study.data.services}
          outcome={study.data.outcomes[0]}
          variant="editorial"
        />
      ))}
    </div>
  </section>
  <MomentumCards />
  <CTASection title="Could your offer be easier to understand?" text="Bring the messy version. We will help you find the simple route through it." />
</BaseLayout>

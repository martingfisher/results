---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you were looking for does not exist. Return to the Results You Can Measure homepage."
>
  <section class="page-hero compact">
    <p class="eyebrow">404</p>
    <h1>That page has gone missing.</h1>
    <p>It may have moved, been renamed, or never existed in the first place. The good news: the rest of the site is still here.</p>
    <div class="actions">
      <a class="btn primary" href="/">Back to home</a>
      <a class="btn secondary" href="/contact/">Book a call</a>
    </div>
  </section>
</BaseLayout>

---
import '../styles/global.css';
import { navItems } from '../data/navigation';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Results You Can Measure is a small creative marketing agency focused on accountable, joined-up marketing.' } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | Results You Can Measure</title>
    <link rel="icon" href="/assets/logos/rycm-isotype-red.svg" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <a class="brand-link" href="/" aria-label="Results You Can Measure home">
        <img src="/assets/logos/rycm-logotype-light.svg" alt="Results You Can Measure" />
      </a>
      <nav class="main-nav" aria-label="Main navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <a class="header-cta" href="/contact/">Book a call</a>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer" aria-labelledby="footer-heading">
      <div class="footer-results" aria-hidden="true">
        <div class="footer-results-track">
          <span>RESULTS</span>
          <span>RESULTS</span>
        </div>
      </div>
      <div class="footer-content">
        <div class="footer-brand">
          <img src="/assets/logos/rycm-logotype-light.svg" alt="Results You Can Measure" />
          <h2 id="footer-heading">More performance, more feedback and more accountability.</h2>
          <p>A small, independent, strong team delivering consultancy, branding, copywriting, PPC, SEO and the fastest, most secure web hosting you will find. Accountable, joined thinking and measurable progress.</p>
          <a class="footer-cta" href="/contact/">Book a call</a>
        </div>
        <div class="footer-column">
          <p class="footer-heading">Explore</p>
          <a href="/services/">Services</a>
          <a href="/case-studies/">Case Studies</a>
          <a href="/blog/">Blog</a>
          <a href="/about/">About</a>
          <a href="/faq/">FAQ</a>
        </div>
        <div class="footer-column">
          <p class="footer-heading">Useful</p>
          <a href="/contact/">Book a call</a>
          <a href="/privacy/">Privacy</a>
          <a href="/cookies/">Cookies</a>
          <a href="https://www.linkedin.com/in/martingfisher/" rel="me noopener" target="_blank">LinkedIn</a>
        </div>
        <address class="footer-contact">
          <p class="footer-heading">Contact</p>
          <a href="mailto:hello@resultsyoucanmeasure.com">hello@resultsyoucanmeasure.com</a>
          <a href="tel:+441274442439">0044 (0)1274 442 439</a>
          <a href="tel:+447973321771">0044 (0)7973 321 771</a>
        </address>
      </div>
      <div class="footer-bottom">
        <span>© {year} Results You Can Measure</span>
        <span>Small. Independent. Strong.</span>
      </div>
    </footer>
  </body>
</html>
